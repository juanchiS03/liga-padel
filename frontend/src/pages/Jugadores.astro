---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gestión de Jugadores">
    <main class="max-w-5xl mx-auto p-8 min-h-screen">
        <div class="flex flex-col md:flex-row gap-8">
            <section class="md:w-1/3">
                <div
                    class="bg-white p-6 rounded-2xl shadow-xl border border-gray-100 sticky top-8"
                >
                    <h2 class="text-2xl font-bold text-gray-800 mb-6">
                        Nuevo Jugador
                    </h2>
                    <form id="jugadorForm" class="space-y-4">
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700"
                                >Nombre</label
                            >
                            <input
                                type="text"
                                name="nombre"
                                class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                                required
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700"
                                >Apellido</label
                            >
                            <input
                                type="text"
                                name="apellido"
                                class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                                required
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700"
                                >Email</label
                            >
                            <input
                                type="email"
                                name="email"
                                class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                                required
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700"
                                >Teléfono</label
                            >
                            <input
                                type="tel"
                                name="telefono"
                                class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
                            />
                        </div>
                        <button
                            type="submit"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg active:scale-95"
                        >
                            Registrar Jugador
                        </button>
                    </form>
                </div>
            </section>

            <section class="md:w-2/3">
                <h2
                    class="text-2xl font-bold text-gray-800 mb-6 flex items-center gap-2"
                >
                    Listado Oficial <span
                        id="contador"
                        class="text-sm bg-gray-200 px-2 py-1 rounded-full text-gray-600"
                        >0</span
                    >
                </h2>
                <div
                    id="listaJugadores"
                    class="grid grid-cols-1 lg:grid-cols-2 gap-4"
                >
                    <div class="animate-pulse bg-gray-200 h-32 rounded-xl">
                    </div>
                    <div class="animate-pulse bg-gray-200 h-32 rounded-xl">
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script>
        import { getJugadores, registrarJugador } from "../services/jugadores";

        const form = document.getElementById("jugadorForm") as HTMLFormElement;
        const lista = document.getElementById("listaJugadores");
        const contador = document.getElementById("contador");

        async function cargarJugadores() {
            try {
                const datos = await getJugadores();
                if (contador) contador.innerText = datos.length.toString();

                if (lista) {
                    if (datos.length === 0) {
                        lista.innerHTML =
                            '<p class="col-span-2 text-gray-400 italic">No hay jugadores registrados aún...</p>';
                        return;
                    }

                    lista.innerHTML = datos
                        .map(
                            (j: any) => `
            <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow group">
              <div class="flex justify-between items-start">
                <div>
                  <h3 class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">${j.nombre} ${j.apellido}</h3>
                  <p class="text-sm text-gray-500">${j.email}</p>
                </div>
                <div class="bg-blue-50 p-2 rounded-lg text-blue-600 text-xs font-bold">#${j.id}</div>
              </div>
              <div class="mt-4 flex items-center text-xs text-gray-400">
                <span class="flex items-center gap-1">📞 ${j.telefono || "Sin tel"}</span>
              </div>
            </div>
          `,
                        )
                        .join("");
                }
            } catch (e) {
                if (lista)
                    lista.innerHTML =
                        '<p class="text-red-500">Error: El servidor Java no responde</p>';
            }
        }

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            await registrarJugador(data);
            form.reset();
            cargarJugadores();
        });

        // Carga inicial
        cargarJugadores();
    </script>
</Layout>
